{"type": "tool_use", "name": "Bash", "input": {"command": "cat > /tmp/koi_score_calib_explore.py << 'EOF'\nimport numpy as np\nfrom sklearn.metrics import average_precision_score\n\nrng = np.random.default_rng(12345)\nN = 50000\n\n# s_std ~ N(0,1) approx (round-2 style latent, standardized)\ns_std = rng.normal(0, 1, size=N)\n\n# try a candidate gamma1 in the new [2.0,4.0] exploration range, gamma0=0 for a rough check\nfor gamma1 in [2.0, 3.0, 4.0]:\n    p = 1.0/(1.0+np.exp(-(gamma1*s_std)))\n    y = rng.binomial(1, p)\n    pos_rate = y.mean()\n\n    flip_prob = 0.03\n    flags = np.zeros((N,4))\n    for k in range(4):\n        flip = rng.binomial(1, flip_prob, size=N)\n        flags[:,k] = np.logical_xor((1-y).astype(bool), flip.astype(bool)).astype(int)\n    flagmean = np.mean(1-flags, axis=1)  # near-binary signal tracking y\n\n    physics_component = 1.0/(1.0+np.exp(-2.0*s_std))\n\n    print(f\"--- gamma1={gamma1}, pos_rate={pos_rate:.3f} ---\")\n    print(\"  baseline AP (physics_component alone, no flag/noise):\", round(average_precision_score(y, physics_component),4))\n    print(\"  baseline AP (flagmean alone, no noise):\", round(average_precision_score(y, flagmean),4))\n\n    for alpha in [0.95, 0.90, 0.85, 0.80]:   # alpha = weight on physics component; (1-alpha)=weight on flag component\n        for sigma in [0.05, 0.15, 0.25, 0.35]:\n            noise = rng.normal(0, sigma, size=N)\n            raw = alpha*physics_component + (1-alpha)*flagmean + noise\n            ap = average_precision_score(y, raw)\n            print(f\"  alpha={alpha:.2f} (flagw={1-alpha:.2f}) sigma={sigma:.2f} -> AP(score alone)={ap:.4f}\")\nEOF\n/home/user/chatmyPT/research-agent/runner/.venv/bin/python /tmp/koi_score_calib_explore.py"}}
